# =============================================================================
# Copia este archivo a .env y ajusta los valores. No subas .env al repositorio.
# =============================================================================

PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/orion_marketplace
MASTER_API_KEY=7987123498172938712398712349871234987123498712349871234987123498
JWT_MEDIA_SECRET=7987123498172938712398712349871234987123498712349871234987123498
JWT_AUTH_SECRET=987123498172938712398712349871234987123498172349871234987123498
# MULTIMEDIA_CONTEXTOS_PERMITIDOS=app_a,orion_marketplace,wallet_app
# -----------------------------------------------------------------------------
# Vercel (producción serverless)
# -----------------------------------------------------------------------------
# Sin S3 (pruebas): STORAGE_DRIVER=local, MONGODB_URI, JWT_AUTH_SECRET,
# JWT_MEDIA_SECRET, PUBLIC_BASE_URL=https://tu-proyecto.vercel.app
# (archivos en /tmp, no persisten; ver README "Despliegue en Vercel").
# Producción recomendada: STORAGE_DRIVER=s3 + S3_BUCKET + credenciales AWS.

# -----------------------------------------------------------------------------
# Desarrollo local: MongoDB + multimedia en disco (Laragon / Compass)
# -----------------------------------------------------------------------------
# Si defines MONGODB_URI, el servidor exige JWT_MEDIA_SECRET cuando STORAGE
# no es S3 (firma GET /api/v1/multimedia/acceso/:token). Sin JWT verás error al arrancar.
#
# Valores de EJEMPLO solo para tu máquina: cámbialos en producción.
# Si no usas Mongo, comenta o borra MONGODB_URI (y MASTER/JWT) y el API va en modo legado.


# -----------------------------------------------------------------------------
# MongoDB (detalle)
# -----------------------------------------------------------------------------
# Misma URI que en MongoDB Compass (New connection).
# Local sin usuario/contraseña: mongodb://127.0.0.1:27017/nombre_base
# Con usuario (Atlas, etc.): mongodb://USUARIO:CONTRASENA@host:27017/nombre_base
#
# MASTER_API_KEY → cabecera X-Master-Key en:
#   POST /api/v1/admin/clientes
#   POST|GET /api/v1/admin/clientes/:clienteId/llaves
#
# JWT_MEDIA_SECRET → no hace falta si usas STORAGE_DRIVER=s3 (solo URLs firmadas S3).

# TTL de URLs firmadas (S3 o JWT en local), segundos entre 60 y 86400.
# SIGNED_URL_EXPIRES_SECONDS=900

# Días de retención de auditoría en MongoDB (índice TTL).
# AUDITORIA_TTL_DIAS=30

# -----------------------------------------------------------------------------
# Modo legado (solo si NO hay MONGODB_URI)
# -----------------------------------------------------------------------------
# API_KEY=

# -----------------------------------------------------------------------------
# Multimedia: disco o S3
# -----------------------------------------------------------------------------
# Lista opcional de slugs de "contexto" (aplicación / producto). Separados por coma.
# Solo aplica en modo legado (sin MONGODB_URI).
# Si está vacío, cualquier slug válido sirve: minúsculas, [a-z0-9_-], máx. 63 chars.
# Ejemplo para fijar solo dos apps: MULTIMEDIA_CONTEXTOS_PERMITIDOS=orion_marketplace,wallet_app
# MULTIMEDIA_CONTEXTOS_PERMITIDOS=

# Carpeta en disco (por defecto: storage). UPLOADS_DIR sigue siendo válido por compatibilidad.
# Los ficheros viven aquí; la URL pública legado "GET /media/..." es solo el prefijo HTTP (no es otra carpeta).
# STORAGE_DIR=storage
# UPLOAD_MAX_MB=5
# PUBLIC_BASE_URL=http://localhost:3000

# STORAGE_DRIVER=local

# Si STORAGE_DRIVER=s3: bucket, región y credenciales AWS.
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_KEY_PREFIX=
# S3_PUBLIC_BASE_URL=
