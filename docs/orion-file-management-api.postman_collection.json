  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Listar clientes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/clientes?q=&activo=",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "clientes"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "",
                  "description": "Búsqueda por email/nombre"
                },
                {
                  "key": "activo",
                  "value": ""
                }
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Crear cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/clientes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "clientes"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"example\",\n  \"nombre\": \"example\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Listar llaves API de un cliente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/clientes/:clienteId/llaves",
              "host": [
                "{{base_url}}"
              ],
              "path": [
