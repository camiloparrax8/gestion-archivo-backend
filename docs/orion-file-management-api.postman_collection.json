                "v1",
                "admin",
                "clientes",
                ":clienteId",
                "llaves",
                ":llaveId",
                "estado"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activo\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
