    {
      "name": "MultimediaPanel",
      "item": [
        {
          "name": "Solicitar URL de lectura (panel JWT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Llave-Id",
                "value": "{{llave_id}}",
                "description": "Opcional en panel JWT: publicId de una API key para filtrar browse y aplicar prefijos. No obligatorio para subir."
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/client/me/multimedia/url-firma",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "client",
                "me",
                "multimedia",
                "url-firma"
              ]
            },
            "description": "Igual que POST /v1/multimedia/url-firma pero con sesión del gestor.\nNo requiere API key; el tenant se deduce del JWT.\nOpcional X-Llave-Id para validar alcance si se envía una llave.\n",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rutaInternaCliente\": \"orion/productos/674a1b2c3d4e5f678901234/galeria/jpeg/1678900000-abc.jpg\",\n  \"segundos\": 900\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Explorar carpetas y archivos (panel JWT)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Llave-Id",
