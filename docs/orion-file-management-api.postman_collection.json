    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuario (bootstrap)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Master-Key",
                "value": "{{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Requiere `X-Master-Key` para evitar registro público.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"example\",\n  \"password\": \"example\",\n  \"rol\": \"example\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Login (JWT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"example\",\n  \"password\": \"example\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "var token = json && json.data && json.data.token;",
                  "if (token) {",
                  "  pm.collectionVariables.set('access_token', token);",
                  "  pm.collectionVariables.set('bearer_token', 'Bearer ' + token);",
                  "  pm.collectionVariables.set('ID_TOKEN', token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Perfil del usuario autenticado",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            }
          }
        }
      ]
