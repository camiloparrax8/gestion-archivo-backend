            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Crear llave API para un cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/clientes/:clienteId/llaves",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "clientes",
                ":clienteId",
                "llaves"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"example\",\n  \"prefijos\": [\n    \"example\"\n  ],\n  \"permisos\": [\n    \"example\"\n  ]\n}",
              "options": {
